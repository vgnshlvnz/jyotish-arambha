  "sign_lordship_derivation": {
    "principle": "Solar/Lunar Hora division. Sun owns Leo (summer solstice zenith), Moon owns adjacent Cancer. Mercury (closest to Sun) owns adjacent Virgo/Gemini; Venus owns next (Libra/Taurus); Mars owns next (Scorpio/Aries); Jupiter owns next (Sagittarius/Pisces); Saturn owns outermost (Capricorn/Aquarius).",
    "solar_half_leo_to_capricorn": ["Leo→Sun", "Virgo→Mercury", "Libra→Venus", "Scorpio→Mars", "Sagittarius→Jupiter", "Capricorn→Saturn"],
    "lunar_half_cancer_to_aquarius": ["Cancer→Moon", "Gemini→Mercury", "Taurus→Venus", "Aries→Mars", "Pisces→Jupiter", "Aquarius→Saturn"]
