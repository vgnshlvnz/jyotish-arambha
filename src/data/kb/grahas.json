  "arohi_avarohi": {
    "description": "Arohi = planet moving from debilitation toward exaltation sign (gaining strength). Avarohi = reverse.",
    "pattern": "Arohi starts 1° after deep debilitation, ends at deep exaltation. Avarohi reverses.",
    "ranges": {
      "Sun": {"arohi": "11° Libra → 10° Aries", "avarohi": "11° Aries → 10° Libra"},
      "Moon": {"arohi": "4° Scorpio → 3° Taurus", "avarohi": "4° Taurus → 3° Scorpio"},
      "Mars": {"arohi": "29° Cancer → 28° Capricorn", "avarohi": "29° Capricorn → 28° Cancer"},
      "Mercury": {"arohi": "16° Pisces → 15° Virgo", "avarohi": "16° Virgo → 15° Pisces"},
      "Jupiter": {"arohi": "6° Capricorn → 5° Cancer", "avarohi": "6° Cancer → 5° Capricorn"},
      "Venus": {"arohi": "28° Virgo → 27° Pisces", "avarohi": "28° Pisces → 27° Virgo"},
      "Saturn": {"arohi": "21° Aries → 20° Libra", "avarohi": "21° Libra → 20° Aries"}
    }
  },
